# ═══════════════════════════════════════════════════════════════
# ESTIA — Παράδειγμα μεταβλητών περιβάλλοντος
# Αντίγραψέ το σε .env (τοπικά) ή όρισέ τα στο Railway (prod).
# ΠΟΤΕ μη βάλεις πραγματικά secrets σε αυτό το αρχείο — βλ. CLAUDE.md §4.
# Στήλη: ΜΕΤΑΒΛΗΤΗ=default_τιμή   # σχόλιο  [Υ]=υποχρεωτική σε prod
# ═══════════════════════════════════════════════════════════════

# ── Πυρήνας ────────────────────────────────────────────────────
SECRET_KEY=                                  # [Υ] Flask session key — υποχρεωτικό σε prod
DATABASE_URL=sqlite:///water.db              # prod: postgresql://... (Railway)
PORT=5000                                    # τοπική θύρα (prod: το ορίζει το Railway)
TZ=Europe/Athens                             # ζώνη ώρας εφαρμογής
APP_URL=https://estia.condianhotels.gr       # base URL για links σε emails

# ── Bootstrap / πρόσβαση ───────────────────────────────────────
BOOTSTRAP_ADMIN_USER=admin                   # πρώτος masteradmin (seed)
BOOTSTRAP_ADMIN_PASSWORD=                     # [Υ στο 1ο boot] κωδικός bootstrap admin
TEAM_DEFAULT_PASSWORD=condian2026            # default κωδικός νέων χρηστών (άλλαξέ τον)
REG_CODE=condian2026                         # κωδικός εγγραφής

# ── Email (SMTP) ───────────────────────────────────────────────
EMAIL_FROM=report@condian.gr                 # αποστολέας ειδοποιήσεων
EMAIL_PASSWORD=                               # κωδικός SMTP

# ── Microsoft Graph (εναλλακτική αποστολή email) ───────────────
GRAPH_TENANT_ID=                              # Azure tenant
GRAPH_CLIENT_ID=                              # app registration client id
GRAPH_CLIENT_SECRET=                          # app secret
GRAPH_SENDER=                                 # mailbox αποστολής (default: EMAIL_FROM)

# ── SharePoint (master sync / backups) ─────────────────────────
SP_HOST=                                      # π.χ. contoso.sharepoint.com
SP_SITE_PATH=                                 # /sites/...
SP_FOLDER=Estia-Backups                       # φάκελος backup
SP_MASTER_FILE=                               # master αρχείο συγχρονισμού
MASTER_SYNC_HOUR=4                            # ώρα master sync (0-23)

# ── AI (SpithaAI — προαιρετικό) ────────────────────────────────
AI_PROVIDER=auto                              # auto | anthropic | openai
AI_MODEL=                                     # συγκεκριμένο model id (κενό=default)
ANTHROPIC_API_KEY=                            # κλειδί Anthropic
OPENAI_API_KEY=                               # κλειδί OpenAI

# ── Scheduler / backups / reminders ────────────────────────────
ENABLE_SCHEDULER=true                         # ενεργοποίηση background scheduler
REMINDER_HOUR=18                              # ώρα ημερήσιων reminders (0-23)
BACKUP_ENABLED=false                          # αυτόματα backups on/off
BACKUP_HOUR=                                  # ώρα backup (μονή τιμή)
BACKUP_HOURS=                                 # ή πολλαπλές ώρες (csv, π.χ. 6,14,22)
BACKUP_KEEP=30                                # πόσα backups κρατάμε
