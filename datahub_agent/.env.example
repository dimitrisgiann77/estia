# Data Hub Agent — config (αντίγραψέ το ως .env και συμπλήρωσε)
# ── Epsilon SQL (read-only login db_datareader) ──
# Windows auth:
EPSILON_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=WIN-TQ396JC4P4R\EPSILON12;DATABASE=bmisthos;Trusted_Connection=yes
# ή SQL login (db_datareader):
# EPSILON_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=WIN-TQ396JC4P4R\EPSILON12;DATABASE=bmisthos;UID=estia_reader;PWD=********

# ── Pylon SQL (read-only login db_datareader) — module Οικονομικά ──
# SERVER = IP\INSTANCE του Pylon server · DATABASE = η βάση Pylon (φαίνεται στο pylon_tables_map)
# SQL login (προτεινόμενο — δικός μας estia_reader από create_reader_login_pylon.sql):
# PYLON_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=<SERVER_IP>\<INSTANCE>;DATABASE=<PYLON_DB>;UID=estia_reader;PWD=********
# ή Windows auth (αν ο agent τρέχει με λογαριασμό που έχει read δικαίωμα):
# PYLON_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=<SERVER_IP>\<INSTANCE>;DATABASE=<PYLON_DB>;Trusted_Connection=yes

# ── Εστία (cloud) ingest endpoint ──
ESTIA_URL=https://estia.condianhotels.gr
# βάλε εδώ το ΠΡΑΓΜΑΤΙΚΟ token (ίδιο με το DATAHUB_INGEST_TOKEN του Railway) — ΜΟΝΟ στο τοπικό .env
ESTIA_TOKEN=REPLACE_WITH_DATAHUB_INGEST_TOKEN

# ── προαιρετικά ──
BATCH=500
